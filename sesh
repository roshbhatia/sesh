#!/usr/bin/env bash
# sesh - Multi-repo session manager
# Manages isolated development workspaces with symlinks to multiple repositories

set -euo pipefail

readonly SESH_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/sesh"
readonly VERSION="1.0.0"

# Dependency checks
check_dependencies() {
    local missing=()
    
    command -v zoxide >/dev/null 2>&1 || missing+=("zoxide")
    command -v fzf >/dev/null 2>&1 || missing+=("fzf")
    command -v gum >/dev/null 2>&1 || missing+=("gum")
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Error: Missing required dependencies: ${missing[*]}" >&2
        echo "Please install them to continue." >&2
        exit 1
    fi
}

# Helper functions
error() {
    gum style --foreground 196 "Error: $1" >&2
    exit 1
}

success() {
    gum style --foreground 42 "$1"
}

info() {
    gum style --foreground 86 "$1"
}

warn() {
    gum style --foreground 214 "$1"
}

get_session_path() {
    local name="$1"
    echo "${SESH_ROOT}/${name}"
}

session_exists() {
    local name="$1"
    [[ -d "$(get_session_path "$name")" ]]
}

validate_session_name() {
    local name="$1"
    
    if [[ -z "$name" ]]; then
        error "Session name cannot be empty"
    fi
    
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        error "Session name must contain only letters, numbers, hyphens, and underscores"
    fi
}

extract_org_repo() {
    local path="$1"
    local parent_dir
    local repo_name
    parent_dir=$(basename "$(dirname "$path")")
    repo_name=$(basename "$path")
    echo "${parent_dir}/${repo_name}"
}

# Core operations
create_session() {
    local name="$1"
    local description="${2:-}"
    
    validate_session_name "$name"
    
    if session_exists "$name"; then
        error "Session '${name}' already exists"
    fi
    
    # Get description if not provided
    if [[ -z "$description" ]]; then
        description=$(gum input --placeholder "Session description (optional)" --prompt "Description: ") || true
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    
    # Create session directory
    mkdir -p "$session_path"
    
    # Write description
    if [[ -n "$description" ]]; then
        echo "$description" > "$session_path/.sesh-desc"
    fi
    
    # Create shell.nix
    cat > "$session_path/shell.nix" <<'EOF'
{ pkgs ? import <nixpkgs> {} }:

pkgs.mkShell {
  buildInputs = with pkgs; [
    # Uncomment the stacks you need:
    
    # Go
    # go gopls golangci-lint air delve
    
    # Node.js
    # nodejs_20 nodePackages.npm nodePackages.pnpm yarn
    
    # Python
    # python311 python311Packages.pip poetry ruff
    
    # Rust
    # cargo rustc rustfmt clippy
    
    # General tools
    # git jq yq ripgrep fd bat
  ];
  
  shellHook = ''
    echo "Session: $(basename $PWD)"
    
    # Uncomment for stack-specific setup:
    
    # Go
    # export GOPATH=$PWD/.go
    # export PATH=$GOPATH/bin:$PATH
    
    # Node.js
    # export NODE_ENV=development
    
    # Python
    # export PYTHONPATH=$PWD
  '';
}
EOF
    
    # Create .envrc
    echo "use nix" > "$session_path/.envrc"
    
    # Select and add repos
    info "Select repositories for this session..."
    sleep 0.5
    select_and_add_repos "$session_path"
    
    success "Created session '${name}'"
    echo "$session_path"
}

list_sessions() {
    if [[ ! -d "$SESH_ROOT" ]] || [[ -z "$(ls -A "$SESH_ROOT" 2>/dev/null)" ]]; then
        info "No sessions found. Create one with: sesh new <name>"
        return
    fi
    
    gum style --border rounded --padding "0 1" --margin "1 0" "Sessions"
    echo
    
    for session_dir in "$SESH_ROOT"/*; do
        if [[ ! -d "$session_dir" ]]; then
            continue
        fi
        
        local name
        local desc=""
        local count=0
        name=$(basename "$session_dir")
        
        if [[ -f "$session_dir/.sesh-desc" ]]; then
            desc=$(cat "$session_dir/.sesh-desc")
        fi
        
        # Count symlinks (repos)
        count=$(find "$session_dir" -type l 2>/dev/null | wc -l | tr -d ' ')
        
        # Format output
        gum style --foreground 212 --bold "$name"
        if [[ -n "$desc" ]]; then
            echo "  $desc"
        fi
        echo "  ${count} repo(s)"
        echo
    done
}

select_and_add_repos() {
    local session_path="$1"
    
    # Use zoxide query with fzf for multi-select
    local selected_repos
    selected_repos=$(zoxide query -l | fzf \
        --multi \
        --height=80% \
        --border=rounded \
        --prompt="Select directories to add (Tab to select, Enter to confirm): " \
        --preview='ls -la {}' \
        --preview-window=right:50% \
        --header='Select directories to add to session') || true
    
    if [[ -z "$selected_repos" ]]; then
        warn "No directories selected"
        return
    fi
    
    # Create symlinks for selected repos
    while IFS= read -r repo_path; do
        create_symlink "$session_path" "$repo_path"
    done <<< "$selected_repos"
}

create_symlink() {
    local session_path="$1"
    local repo_path="$2"
    
    if [[ ! -e "$repo_path" ]]; then
        warn "Path does not exist, skipping: $repo_path"
        return
    fi
    
    local org_repo
    local link_path
    org_repo=$(extract_org_repo "$repo_path")
    link_path="$session_path/$org_repo"
    
    # Create parent directory if needed
    mkdir -p "$(dirname "$link_path")"
    
    # Create symlink
    if [[ -e "$link_path" ]]; then
        warn "Symlink already exists, skipping: $org_repo"
    else
        ln -s "$repo_path" "$link_path"
        success "  Linked: $org_repo"
    fi
}

add_repos_to_session() {
    local name="$1"
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    info "Adding repositories to session '${name}'..."
    select_and_add_repos "$session_path"
}

remove_repos_from_session() {
    local name="$1"
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    
    # Find all symlinks in the session
    local symlinks
    symlinks=$(find "$session_path" -type l -exec echo {} \; 2>/dev/null | sed "s|^$session_path/||" || true)
    
    if [[ -z "$symlinks" ]]; then
        warn "No directories found in session '${name}'"
        return
    fi
    
    # Use fzf for multi-select
    local to_remove
    to_remove=$(echo "$symlinks" | fzf \
        --multi \
        --height=80% \
        --border=rounded \
        --prompt="Select directories to remove (Tab to select, Enter to confirm): " \
        --header="Remove directories from session: ${name}") || true
    
    if [[ -z "$to_remove" ]]; then
        info "No directories selected for removal"
        return
    fi
    
    # Remove selected symlinks
    while IFS= read -r link; do
        local full_path="$session_path/$link"
        if [[ -L "$full_path" ]]; then
            rm "$full_path"
            success "  Removed: $link"
            
            # Clean up empty parent directories
            local parent_dir
            parent_dir=$(dirname "$full_path")
            if [[ -d "$parent_dir" ]] && [[ -z "$(ls -A "$parent_dir" 2>/dev/null)" ]]; then
                rmdir "$parent_dir"
            fi
        fi
    done <<< "$to_remove"
}

delete_session() {
    local name="$1"
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    
    # Check if this is a worktree session
    local is_worktree=false
    if [[ -f "$session_path/.sesh-worktree" ]]; then
        is_worktree=true
        info "This is a worktree session"
    fi
    
    # Confirm deletion
    gum confirm "Delete session '${name}'? This cannot be undone." || {
        info "Deletion cancelled"
        exit 0
    }
    
    # If worktree session, clean up worktrees first
    if [[ "$is_worktree" == "true" ]]; then
        info "Cleaning up git worktrees..."
        local repos
        repos=$(get_repo_links "$session_path")
        
        while IFS= read -r link_path; do
            local worktree_path
            worktree_path=$(readlink "$link_path")
            
            if [[ -d "$worktree_path" ]] && is_git_repo "$worktree_path"; then
                # Find the main repo by asking git
                local main_repo
                main_repo=$(git -C "$worktree_path" rev-parse --git-common-dir 2>/dev/null | sed 's|/.git/worktrees/.*||')
                
                if [[ -n "$main_repo" ]] && [[ -d "$main_repo" ]]; then
                    # Remove the worktree
                    if git -C "$main_repo" worktree remove "$worktree_path" --force 2>/dev/null; then
                        success "  Removed worktree: $(basename "$worktree_path")"
                    else
                        # Try removing the directory if git worktree remove failed
                        rm -rf "$worktree_path"
                        git -C "$main_repo" worktree prune 2>/dev/null || true
                    fi
                fi
            fi
        done <<< "$repos"
    fi
    
    rm -rf "$session_path"
    success "Deleted session '${name}'"
}

rename_session() {
    local old_name="$1"
    local new_name="$2"
    
    if ! session_exists "$old_name"; then
        error "Session '${old_name}' does not exist"
    fi
    
    validate_session_name "$new_name"
    
    if session_exists "$new_name"; then
        error "Session '${new_name}' already exists"
    fi
    
    local old_path
    old_path=$(get_session_path "$old_name")
    local new_path
    new_path=$(get_session_path "$new_name")
    
    mv "$old_path" "$new_path"
    success "Renamed session '${old_name}' to '${new_name}'"
    echo "$new_path"
}

update_description() {
    local name="$1"
    local description="${2:-}"
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    
    # If no description provided, show current description
    if [[ -z "$description" ]]; then
        if [[ -f "$session_path/.sesh-desc" ]]; then
            cat "$session_path/.sesh-desc"
        else
            info "No description set for session '${name}'"
        fi
        return
    fi
    
    # Update description
    echo "$description" > "$session_path/.sesh-desc"
    success "Updated description for session '${name}'"
}

init_shell() {
    local shell_type="${1:-zsh}"
    
    if [[ "$shell_type" != "zsh" ]]; then
        error "Only zsh is currently supported"
    fi
    
    cat <<'INIT_EOF'
# sesh shell integration

# s - Quick navigate to session
s() {
    local session_path
    session_path=$(sesh "$1" 2>/dev/null)
    if [[ -n "$session_path" && -d "$session_path" ]]; then
        cd "$session_path" || return 1
    else
        echo "Session '$1' not found" >&2
        return 1
    fi
}

# si - Interactive session selector (cd to selected)
si() {
    if [[ ! -d "${XDG_STATE_HOME:-$HOME/.local/state}/sesh" ]] || \
       [[ -z "$(ls -A "${XDG_STATE_HOME:-$HOME/.local/state}/sesh" 2>/dev/null)" ]]; then
        echo "No sessions found. Create one with: sesh new <name>" >&2
        return 1
    fi
    
    local sessions=()
    local sesh_root="${XDG_STATE_HOME:-$HOME/.local/state}/sesh"
    
    for session_dir in "$sesh_root"/*; do
        if [[ -d "$session_dir" ]]; then
            sessions+=("$(basename "$session_dir")")
        fi
    done
    
    local choice
    choice=$(printf '%s\n' "${sessions[@]}" | fzf \
        --height=40% \
        --border=rounded \
        --prompt="Select session: " \
        --preview="ls -la $sesh_root/{}" \
        --preview-window=right:50%)
    
    if [[ -n "$choice" ]]; then
        s "$choice"
    fi
}

# Completion for s and si
_sesh_complete_sessions() {
    local sesh_root="${XDG_STATE_HOME:-$HOME/.local/state}/sesh"
    if [[ -d "$sesh_root" ]]; then
        local sessions=(${sesh_root}/*(/:t))
        _describe 'session' sessions
    fi
}

compdef _sesh_complete_sessions s
compdef _sesh_complete_sessions si

# Enhanced sesh completion
_sesh_enhanced() {
    local line state

    function _sesh_sessions {
        local sesh_root="${XDG_STATE_HOME:-$HOME/.local/state}/sesh"
        if [[ -d "$sesh_root" ]]; then
            local sessions=(${sesh_root}/*(/:t))
            _describe 'session' sessions
        fi
    }

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            local -a commands
            commands=(
                'new:Create a new session'
                'list:List all sessions'
                'add:Add repos to an existing session'
                'remove:Remove repos from a session'
                'delete:Delete a session'
                'rename:Rename a session'
                'describe:Show or update session description'
                'branch:Manage git branches across repos'
                'status:Show git status for all repos'
                'sync:Pull updates for all repos'
                'exec:Execute command in all repos'
                'init:Initialize shell integration'
                'help:Show help message'
                'version:Show version'
            )
            _describe 'command' commands
            _sesh_sessions
            ;;
        args)
            case $line[1] in
                add|remove|delete|describe|branch|status|sync|exec)
                    _sesh_sessions
                    ;;
                rename)
                    if [[ $CURRENT -eq 2 ]]; then
                        _sesh_sessions
                    fi
                    ;;
            esac
            ;;
    esac
}

compdef _sesh_enhanced sesh
INIT_EOF
}

# Git integration helpers

get_repo_links() {
    local session_path="$1"
    find "$session_path" -type l 2>/dev/null | sort
}

is_git_repo() {
    local path="$1"
    [[ -d "$path/.git" ]] || git -C "$path" rev-parse --git-dir >/dev/null 2>&1
}

git_status_session() {
    local name="$1"
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    
    local repos
    repos=$(get_repo_links "$session_path")
    
    if [[ -z "$repos" ]]; then
        warn "No repositories found in session '${name}'"
        return
    fi
    
    info "Git status for session: ${name}"
    echo
    
    local has_errors=0
    
    while IFS= read -r link_path; do
        local repo_path
        repo_path=$(readlink "$link_path")
        local repo_name
        repo_name=$(echo "$link_path" | sed "s|^$session_path/||")
        
        if [[ ! -d "$repo_path" ]]; then
            warn "  ${repo_name}: Target does not exist"
            has_errors=1
            continue
        fi
        
        if ! is_git_repo "$repo_path"; then
            warn "  ${repo_name}: Not a git repository"
            continue
        fi
        
        # Get git info
        local branch
        branch=$(git -C "$repo_path" branch --show-current 2>/dev/null || echo "detached")
        
        local status_output
        status_output=$(git -C "$repo_path" status --porcelain 2>/dev/null)
        
        local ahead_behind
        ahead_behind=$(git -C "$repo_path" rev-list --left-right --count @{upstream}...HEAD 2>/dev/null || echo "")
        
        # Format output
        gum style --foreground 212 "  ${repo_name}"
        echo "    Branch: ${branch}"
        
        if [[ -n "$ahead_behind" ]]; then
            local behind ahead
            behind=$(echo "$ahead_behind" | awk '{print $1}')
            ahead=$(echo "$ahead_behind" | awk '{print $2}')
            if [[ "$behind" -gt 0 ]] || [[ "$ahead" -gt 0 ]]; then
                echo "    Remote: ↓${behind} ↑${ahead}"
            else
                echo "    Remote: synced"
            fi
        else
            echo "    Remote: no upstream"
        fi
        
        if [[ -z "$status_output" ]]; then
            gum style --foreground 42 "    Status: clean"
        else
            local modified
            modified=$(echo "$status_output" | grep -c "^ M" || true)
            local untracked
            untracked=$(echo "$status_output" | grep -c "^??" || true)
            local staged
            staged=$(echo "$status_output" | grep -c "^[MADR]" || true)
            
            gum style --foreground 214 "    Status: ${modified} modified, ${staged} staged, ${untracked} untracked"
        fi
        echo
    done <<< "$repos"
    
    return $has_errors
}

git_sync_session() {
    local name="$1"
    local fetch_only="${2:-false}"
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    
    local repos
    repos=$(get_repo_links "$session_path")
    
    if [[ -z "$repos" ]]; then
        warn "No repositories found in session '${name}'"
        return
    fi
    
    info "Syncing repositories in session: ${name}"
    echo
    
    local failed=0
    local succeeded=0
    
    while IFS= read -r link_path; do
        local repo_path
        repo_path=$(readlink "$link_path")
        local repo_name
        repo_name=$(echo "$link_path" | sed "s|^$session_path/||")
        
        if [[ ! -d "$repo_path" ]]; then
            warn "  ${repo_name}: Target does not exist"
            ((failed++))
            continue
        fi
        
        if ! is_git_repo "$repo_path"; then
            warn "  ${repo_name}: Not a git repository"
            ((failed++))
            continue
        fi
        
        # Check for uncommitted changes if pulling
        if [[ "$fetch_only" == "false" ]]; then
            local status_output
            status_output=$(git -C "$repo_path" status --porcelain 2>/dev/null)
            if [[ -n "$status_output" ]]; then
                warn "  ${repo_name}: Has uncommitted changes, skipping pull"
                ((failed++))
                continue
            fi
        fi
        
        # Perform git operation
        if [[ "$fetch_only" == "true" ]]; then
            if git -C "$repo_path" fetch --all --quiet 2>/dev/null; then
                success "  ${repo_name}: Fetched"
                ((succeeded++))
            else
                warn "  ${repo_name}: Fetch failed"
                ((failed++))
            fi
        else
            if git -C "$repo_path" pull --quiet 2>/dev/null; then
                success "  ${repo_name}: Pulled"
                ((succeeded++))
            else
                warn "  ${repo_name}: Pull failed"
                ((failed++))
            fi
        fi
    done <<< "$repos"
    
    echo
    info "Summary: ${succeeded} succeeded, ${failed} failed"
    
    return $([[ $failed -eq 0 ]] && echo 0 || echo 1)
}

git_exec_session() {
    local name="$1"
    shift
    local cmd=("$@")
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    if [[ ${#cmd[@]} -eq 0 ]]; then
        error "No command specified"
    fi
    
    local session_path
    session_path=$(get_session_path "$name")
    
    local repos
    repos=$(get_repo_links "$session_path")
    
    if [[ -z "$repos" ]]; then
        warn "No repositories found in session '${name}'"
        return
    fi
    
    info "Executing in session: ${name}"
    info "Command: ${cmd[*]}"
    echo
    
    local failed=0
    local succeeded=0
    
    while IFS= read -r link_path; do
        local repo_path
        repo_path=$(readlink "$link_path")
        local repo_name
        repo_name=$(echo "$link_path" | sed "s|^$session_path/||")
        
        if [[ ! -d "$repo_path" ]]; then
            warn "  ${repo_name}: Target does not exist"
            ((failed++))
            continue
        fi
        
        gum style --foreground 212 "  ${repo_name}:"
        
        if (cd "$repo_path" && "${cmd[@]}" 2>&1 | sed 's/^/    /'); then
            ((succeeded++))
        else
            ((failed++))
        fi
        echo
    done <<< "$repos"
    
    info "Summary: ${succeeded} succeeded, ${failed} failed"
    
    return $([[ $failed -eq 0 ]] && echo 0 || echo 1)
}

git_branch_session() {
    local name="$1"
    local branch_name="${2:-}"
    local use_worktree="${3:-false}"
    
    if ! session_exists "$name"; then
        error "Session '${name}' does not exist"
    fi
    
    # If no branch name, show branch status
    if [[ -z "$branch_name" ]] || [[ "$branch_name" == "--status" ]]; then
        git_branch_status "$name"
        return
    fi
    
    # Handle worktree creation
    if [[ "$use_worktree" == "true" ]]; then
        git_branch_worktree "$name" "$branch_name"
        return
    fi
    
    # Regular branch checkout/create
    local session_path
    session_path=$(get_session_path "$name")
    
    local repos
    repos=$(get_repo_links "$session_path")
    
    if [[ -z "$repos" ]]; then
        warn "No repositories found in session '${name}'"
        return
    fi
    
    info "Switching to branch '${branch_name}' in session: ${name}"
    echo
    
    local failed=0
    local succeeded=0
    
    while IFS= read -r link_path; do
        local repo_path
        repo_path=$(readlink "$link_path")
        local repo_name
        repo_name=$(echo "$link_path" | sed "s|^$session_path/||")
        
        if [[ ! -d "$repo_path" ]]; then
            warn "  ${repo_name}: Target does not exist"
            ((failed++))
            continue
        fi
        
        if ! is_git_repo "$repo_path"; then
            warn "  ${repo_name}: Not a git repository"
            ((failed++))
            continue
        fi
        
        # Check if branch exists
        if git -C "$repo_path" rev-parse --verify "$branch_name" >/dev/null 2>&1; then
            # Branch exists, check it out
            if git -C "$repo_path" checkout "$branch_name" --quiet 2>/dev/null; then
                success "  ${repo_name}: Switched to existing branch"
                ((succeeded++))
            else
                warn "  ${repo_name}: Failed to checkout branch"
                ((failed++))
            fi
        else
            # Branch doesn't exist, create it
            if git -C "$repo_path" checkout -b "$branch_name" --quiet 2>/dev/null; then
                success "  ${repo_name}: Created and switched to new branch"
                ((succeeded++))
            else
                warn "  ${repo_name}: Failed to create branch"
                ((failed++))
            fi
        fi
    done <<< "$repos"
    
    echo
    info "Summary: ${succeeded} succeeded, ${failed} failed"
    
    return $([[ $failed -eq 0 ]] && echo 0 || echo 1)
}

git_branch_status() {
    local name="$1"
    
    local session_path
    session_path=$(get_session_path "$name")
    
    local repos
    repos=$(get_repo_links "$session_path")
    
    if [[ -z "$repos" ]]; then
        warn "No repositories found in session '${name}'"
        return
    fi
    
    info "Branch status for session: ${name}"
    echo
    
    while IFS= read -r link_path; do
        local repo_path
        repo_path=$(readlink "$link_path")
        local repo_name
        repo_name=$(echo "$link_path" | sed "s|^$session_path/||")
        
        if [[ ! -d "$repo_path" ]] || ! is_git_repo "$repo_path"; then
            continue
        fi
        
        local branch
        branch=$(git -C "$repo_path" branch --show-current 2>/dev/null || echo "detached")
        
        local default_branch
        default_branch=$(git -C "$repo_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
        
        gum style --foreground 212 "  ${repo_name}"
        echo "    Current: ${branch}"
        echo "    Default: ${default_branch}"
        echo
    done <<< "$repos"
}

git_branch_worktree() {
    local source_session="$1"
    local branch_name="$2"
    
    # Generate new session name
    local new_session="${source_session}-${branch_name}"
    
    # Check if new session already exists
    if session_exists "$new_session"; then
        error "Session '${new_session}' already exists. Choose a different branch name or delete the existing session."
    fi
    
    local source_path
    source_path=$(get_session_path "$source_session")
    
    local new_path
    new_path=$(get_session_path "$new_session")
    
    info "Creating worktree session: ${new_session}"
    info "Based on: ${source_session}"
    info "Branch: ${branch_name}"
    echo
    
    # Create new session directory
    mkdir -p "$new_path"
    
    # Copy metadata files
    if [[ -f "$source_path/.sesh-desc" ]]; then
        cp "$source_path/.sesh-desc" "$new_path/.sesh-desc"
        echo " (worktree for ${branch_name})" >> "$new_path/.sesh-desc"
    fi
    
    if [[ -f "$source_path/shell.nix" ]]; then
        cp "$source_path/shell.nix" "$new_path/shell.nix"
    fi
    
    if [[ -f "$source_path/.envrc" ]]; then
        cp "$source_path/.envrc" "$new_path/.envrc"
    fi
    
    # Mark as worktree session
    echo "$source_session" > "$new_path/.sesh-worktree"
    
    # Get all repos from source session
    local repos
    repos=$(get_repo_links "$source_path")
    
    if [[ -z "$repos" ]]; then
        warn "No repositories found in source session"
        rm -rf "$new_path"
        return 1
    fi
    
    local failed=0
    local succeeded=0
    
    while IFS= read -r link_path; do
        local repo_path
        repo_path=$(readlink "$link_path")
        local repo_name
        repo_name=$(echo "$link_path" | sed "s|^$source_path/||")
        
        if [[ ! -d "$repo_path" ]]; then
            warn "  ${repo_name}: Source target does not exist"
            ((failed++))
            continue
        fi
        
        if ! is_git_repo "$repo_path"; then
            warn "  ${repo_name}: Not a git repository"
            ((failed++))
            continue
        fi
        
        # Create worktree in a sibling directory
        local worktree_base
        worktree_base=$(dirname "$repo_path")
        local repo_basename
        repo_basename=$(basename "$repo_path")
        local worktree_path="${worktree_base}/${repo_basename}-wt-${branch_name}"
        
        # Create worktree
        if git -C "$repo_path" worktree add "$worktree_path" -b "$branch_name" 2>/dev/null || \
           git -C "$repo_path" worktree add "$worktree_path" "$branch_name" 2>/dev/null; then
            # Create symlink in new session
            local link_target="$new_path/$repo_name"
            mkdir -p "$(dirname "$link_target")"
            ln -s "$worktree_path" "$link_target"
            success "  ${repo_name}: Created worktree"
            ((succeeded++))
        else
            warn "  ${repo_name}: Failed to create worktree"
            ((failed++))
        fi
    done <<< "$repos"
    
    echo
    if [[ $succeeded -gt 0 ]]; then
        success "Created worktree session: ${new_session}"
        echo "$new_path"
    else
        error "Failed to create worktree session"
        rm -rf "$new_path"
        return 1
    fi
    
    info "Summary: ${succeeded} succeeded, ${failed} failed"
    
    return $([[ $failed -eq 0 ]] && echo 0 || echo 1)
}

interactive_menu() {
    # Check if any sessions exist
    local has_sessions=false
    if [[ -d "$SESH_ROOT" ]] && [[ -n "$(ls -A "$SESH_ROOT" 2>/dev/null)" ]]; then
        has_sessions=true
    fi
    
    local options=()
    if $has_sessions; then
        options+=("Open existing session")
    fi
    options+=("Create new session")
    if $has_sessions; then
        options+=("List all sessions")
    fi
    options+=("Exit")
    
    local choice
    choice=$(printf '%s\n' "${options[@]}" | fzf \
        --height=40% \
        --border=rounded \
        --prompt="What would you like to do? " \
        --header="Sesh - Session Manager") || exit 0
    
    case "$choice" in
        "Open existing session")
            open_existing_session
            ;;
        "Create new session")
            local name
            name=$(gum input --placeholder "Session name" --prompt "Name: ")
            if [[ -n "$name" ]]; then
                create_session "$name"
            else
                warn "Session name cannot be empty"
            fi
            ;;
        "List all sessions")
            list_sessions
            ;;
        "Exit")
            exit 0
            ;;
        *)
            exit 0
            ;;
    esac
}

open_existing_session() {
    if [[ ! -d "$SESH_ROOT" ]] || [[ -z "$(ls -A "$SESH_ROOT" 2>/dev/null)" ]]; then
        warn "No sessions found"
        return
    fi
    
    local sessions=()
    for session_dir in "$SESH_ROOT"/*; do
        if [[ -d "$session_dir" ]]; then
            sessions+=("$(basename "$session_dir")")
        fi
    done
    
    local choice
    choice=$(printf '%s\n' "${sessions[@]}" | fzf \
        --height=40% \
        --border=rounded \
        --prompt="Select a session: " \
        --preview="ls -la $SESH_ROOT/{}" \
        --preview-window=right:50%) || return
    
    if [[ -n "$choice" ]]; then
        get_session_path "$choice"
    fi
}

show_usage() {
    cat <<EOF
sesh - Multi-repo session manager v${VERSION}

Usage:
  sesh                          Interactive mode
  sesh <session-name>           Print path to session
  sesh new <name> [desc]        Create new session
  sesh list                     List all sessions
  sesh add <session-name>       Add repos to session
  sesh remove <session-name>    Remove repos from session
  sesh delete <session-name>    Delete a session
  sesh rename <old> <new>       Rename a session
  sesh describe <session> [desc] Show/update session description
  sesh init [zsh]               Output shell integration code
  
Git Integration:
  sesh branch <session> <name>  Checkout/create branch in all repos
  sesh branch <session> <name> --worktree  Create worktree session
  sesh branch <session> --status Show branch info for all repos
  sesh status <session>         Show git status for all repos
  sesh sync <session>           Pull updates for all repos
  sesh sync <session> --fetch   Fetch only (no pull)
  sesh exec <session> <cmd>     Execute command in all repos
  sesh help                     Show this help message

Shell Integration:
  Add to your .zshrc:
    eval "\$(sesh init zsh)"
  
  This provides:
    s <session>    - Quick navigate to session
    si             - Interactive session selector
    Tab completion for all sesh commands

Examples:
  sesh                          # Interactive menu
  sesh new my-project           # Create new session
  cd "\$(sesh my-project)"       # Change to session directory
  eval "\$(sesh init zsh)"       # Shell integration
  s my-project                  # Quick navigate (after init)
  
  # Git workflows
  sesh branch platform feat-x   # Switch all repos to feat-x branch
  sesh branch platform feat-x --worktree  # Create isolated worktree session
  sesh status platform          # Check git status
  sesh sync platform            # Pull all repos
  sesh exec platform git fetch  # Run git command in all repos

EOF
}

# Main entry point
main() {
    check_dependencies
    
    # Ensure sesh root exists
    mkdir -p "$SESH_ROOT"
    
    case "${1:-}" in
        ""|"--interactive")
            interactive_menu
            ;;
        "list"|"-l"|"--list")
            list_sessions
            ;;
        "new"|"create")
            if [[ $# -lt 2 ]]; then
                error "Usage: sesh new <name> [description]"
            fi
            create_session "${2}" "${3:-}"
            ;;
        "add")
            if [[ $# -ne 2 ]]; then
                error "Usage: sesh add <session-name>"
            fi
            add_repos_to_session "${2}"
            ;;
        "remove"|"rm")
            if [[ $# -ne 2 ]]; then
                error "Usage: sesh remove <session-name>"
            fi
            remove_repos_from_session "${2}"
            ;;
        "delete"|"del")
            if [[ $# -ne 2 ]]; then
                error "Usage: sesh delete <session-name>"
            fi
            delete_session "${2}"
            ;;
        "rename"|"mv")
            if [[ $# -ne 3 ]]; then
                error "Usage: sesh rename <old-name> <new-name>"
            fi
            rename_session "${2}" "${3}"
            ;;
        "describe"|"desc")
            if [[ $# -lt 2 ]]; then
                error "Usage: sesh describe <session-name> [description]"
            fi
            update_description "${2}" "${3:-}"
            ;;
        "init")
            init_shell "${2:-zsh}"
            ;;
        "status")
            if [[ $# -ne 2 ]]; then
                error "Usage: sesh status <session-name>"
            fi
            git_status_session "${2}"
            ;;
        "sync")
            if [[ $# -lt 2 ]]; then
                error "Usage: sesh sync <session-name> [--fetch]"
            fi
            local fetch_only="false"
            if [[ "${3:-}" == "--fetch" ]]; then
                fetch_only="true"
            fi
            git_sync_session "${2}" "$fetch_only"
            ;;
        "exec")
            if [[ $# -lt 3 ]]; then
                error "Usage: sesh exec <session-name> <command> [args...]"
            fi
            local session_name="${2}"
            shift 2
            git_exec_session "$session_name" "$@"
            ;;
        "branch")
            if [[ $# -lt 2 ]]; then
                error "Usage: sesh branch <session-name> [branch-name] [--worktree|--status]"
            fi
            local session_name="${2}"
            local branch_name="${3:-}"
            local use_worktree="false"
            
            # Check if --worktree flag is present
            if [[ "${4:-}" == "--worktree" ]] || [[ "$branch_name" == "--worktree" ]]; then
                use_worktree="true"
                # If --worktree is in position 3, we need branch name in position 4
                if [[ "$branch_name" == "--worktree" ]]; then
                    error "Usage: sesh branch <session-name> <branch-name> --worktree"
                fi
            fi
            
            git_branch_session "$session_name" "$branch_name" "$use_worktree"
            ;;
        "help"|"-h"|"--help")
            show_usage
            ;;
        "version"|"-v"|"--version")
            echo "sesh v${VERSION}"
            ;;
        *)
            # Assume it's a session name
            if session_exists "${1}"; then
                get_session_path "${1}"
            else
                error "Session '${1}' does not exist. Use 'sesh list' to see available sessions."
            fi
            ;;
    esac
}

main "$@"
