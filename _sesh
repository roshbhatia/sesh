#compdef sesh

_sesh() {
    local line state

    function _sesh_sessions {
        local -a sessions
        if [[ -d "${XDG_STATE_HOME:-$HOME/.local/state}/sesh" ]]; then
            sessions=(${XDG_STATE_HOME:-$HOME/.local/state}/sesh/*(/:t))
            _describe 'session' sessions
        fi
    }

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            local -a commands
            commands=(
                'new:Create a new session'
                'list:List all sessions'
                'add:Add repos to an existing session'
                'remove:Remove repos from a session'
                'delete:Delete a session'
                'rename:Rename a session'
                'help:Show help message'
                'version:Show version'
            )
            _describe 'command' commands
            _sesh_sessions
            ;;
        args)
            case $line[1] in
                add|remove|delete)
                    _sesh_sessions
                    ;;
                rename)
                    if [[ $CURRENT -eq 2 ]]; then
                        _sesh_sessions
                    fi
                    ;;
            esac
            ;;
    esac
}

_sesh "$@"
